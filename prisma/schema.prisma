model Teams {
  id              String   @id @default(uuid())
  organizationId String @map("organization_id")
  name            String
  description     String?
  leadId         String? @map("lead_id")
  createdById    String @map("created_by_id")
  memberCount    Int      @default(0) @map("member_count")
  departmentId  String? @map("department_id")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @map("updated_at") @updatedAt

  organization Organizations @relation(fields: [organizationId], references: [id])
  lead         Users?        @relation("TeamLead", fields: [leadId], references: [id])
  createdBy   Users         @relation("TeamCreatedBy", fields: [createdById], references: [id])
  department  Departments?  @relation(fields: [departmentId], references: [id])
  members     TeamMembers[]

  @@unique([organizationId, name])
  @@index([organizationId])
  @@index([organizationId, name])
  @@index([departmentId])
}

model Departments {
  id              String   @id @default(uuid())
  organizationId String @map("organization_id")
  name            String
  description     String?
  headId         String? @map("head_id")
  createdById    String @map("created_by_id")
  teamCount      Int      @default(0) @map("team_count")
  memberCount    Int      @default(0) @map("member_count")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @map("updated_at") @updatedAt

  organization Organizations @relation(fields: [organizationId], references: [id])
  head         Users?        @relation("DepartmentHead", fields: [headId], references: [id])
  createdBy   Users         @relation("DepartmentCreatedBy", fields: [createdById], references: [id])
  teams       Teams[]

  @@unique([organizationId, name])
  @@index([organizationId])
  @@index([organizationId, name])
}

model TeamMembers {
  id             String   @id @default(uuid())
  teamId        String @map("team_id")
  userId        String @map("user_id")
  role           String   @default("member")
  joinedAt      DateTime @default(now()) @map("joined_at")
  organizationId String @map("organization_id")

  team Teams @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user Users  @relation(fields: [userId], references: [id])

  @@unique([teamId, userId])
  @@index([teamId])
  @@index([userId])
  @@index([organizationId])
}

