generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model AddonProducts {
  id              String   @id @default(uuid())
  name            String
  description     String?
  type            String   @default("credits")
  creditsAmount  Int? @map("credits_amount")
  stripePriceId String? @map("stripe_price_id")
  priceCents     Int @map("price_cents")
  currency        String   @default("usd")
  isActive       Boolean  @default(true) @map("is_active")
  metadata        Json?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @map("updated_at") @updatedAt

  @@index([isActive])
  @@index([isActive, type])
  @@index([type])

  userAddons UserAddons[]
}

model AiAgentAnalytics {
  id                   String   @id @default(uuid())
  agentId             String @map("agent_id")
  organizationId      String @map("organization_id")
  date                 DateTime
  runsCount           Int      @default(0) @map("runs_count")
  successCount        Int      @default(0) @map("success_count")
  failureCount        Int      @default(0) @map("failure_count")
  totalTokens         Int      @default(0) @map("total_tokens")
  totalCost           Float    @default(0) @map("total_cost")
  avgLatency          Float    @default(0) @map("avg_latency")
  toolCalls           Int      @default(0) @map("tool_calls")
  memoryRetrievals    Int      @default(0) @map("memory_retrievals")
  knowledgeRetrievals Int      @default(0) @map("knowledge_retrievals")
  avgResponseQuality Float? @map("avg_response_quality")
  createdAt           DateTime @default(now()) @map("created_at")

  @@unique([agentId, date])
  @@index([agentId, date])
  @@index([agentId])
  @@index([date])
  @@index([organizationId])
}

model AiAgentConversations {
  id              String   @id @default(uuid())
  agentId        String @map("agent_id")
  runId          String? @map("run_id")
  organizationId String @map("organization_id")
  userId         String @map("user_id")
  title           String?
  metadata        Json?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @map("updated_at") @updatedAt

  @@index([agentId])
  @@index([agentId, updatedAt])
  @@index([organizationId])
  @@index([runId])
  @@index([userId])
}

model AiAgentKnowledgeBases {
  id                String   @id @default(uuid())
  agentId          String @map("agent_id")
  organizationId   String @map("organization_id")
  userId           String @map("user_id")
  name              String
  description       String?
  chunkingStrategy String? @map("chunking_strategy")
  chunkSize        Int      @default(500) @map("chunk_size")
  chunkOverlap     Int      @default(50) @map("chunk_overlap")
  embeddingModel   String? @map("embedding_model")
  metadata          Json?
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @map("updated_at") @updatedAt

  @@index([agentId])
  @@index([organizationId])
  @@index([userId])
}

model AiAgentKnowledgeDocuments {
  id                String   @id @default(uuid())
  knowledgeBaseId String @map("knowledge_base_id")
  organizationId   String @map("organization_id")
  userId           String @map("user_id")
  title             String
  source            String
  sourceType       String @map("source_type")
  content           String
  chunks            Json?
  embedding         Json?
  metadata          Json?
  tokens            Int      @default(0)
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @map("updated_at") @updatedAt

  @@index([knowledgeBaseId])
  @@index([knowledgeBaseId, sourceType])
  @@index([organizationId])
  @@index([sourceType])
  @@index([userId])
}

model AiAgentMemories {
  id              String          @id @default(uuid())
  agentId        String @map("agent_id")
  runId          String? @map("run_id")
  organizationId String @map("organization_id")
  userId         String @map("user_id")
  type            AgentMemoryType @default(SHORT_TERM)
  key             String
  content         String
  summary         String?
  tokens          Int             @default(0)
  metadata        Json?
  score           Float?          @default(0)
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime @map("updated_at") @updatedAt
  expiresAt      DateTime? @map("expires_at")
  embedding       String?

  @@unique([agentId, key])
  @@index([agentId])
  @@index([agentId, key])
  @@index([agentId, type])
  @@index([expiresAt])
  @@index([organizationId])
  @@index([runId])
  @@index([score])
  @@index([type])
  @@index([userId])
}

model AiAgentMessages {
  id              String           @id @default(uuid())
  conversationId String @map("conversation_id")
  role            ConversationRole
  content         String
  toolCalls      Json? @map("tool_calls")
  toolResults    Json? @map("tool_results")
  tokens          Int              @default(0)
  metadata        Json?
  createdAt      DateTime         @default(now()) @map("created_at")

  @@index([conversationId, createdAt])
  @@index([conversationId])
}

model AiAgentRuns {
  id              String    @id @default(uuid())
  agentId        String @map("agent_id")
  organizationId String @map("organization_id")
  userId         String @map("user_id")
  status          String    @default("PENDING")
  triggerType    String? @map("trigger_type")
  input           Json?
  output          Json?
  error           String?
  startedAt      DateTime? @map("started_at")
  completedAt    DateTime? @map("completed_at")
  duration        Int?
  tokensUsed     Int? @map("tokens_used")
  cost            Float?
  metadata        Json?
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime @map("updated_at") @updatedAt

  @@index([agentId, createdAt])
  @@index([agentId])
  @@index([agentId, status])
  @@index([organizationId, createdAt])
  @@index([organizationId])
  @@index([status])
  @@index([userId])
}

model AiAgentSchedules {
  id              String    @id @default(uuid())
  agentId        String @map("agent_id")
  organizationId String @map("organization_id")
  userId         String @map("user_id")
  cron            String
  input           Json?
  enabled         Boolean   @default(true)
  lastFiredAt   DateTime? @map("last_fired_at")
  nextRunAt     DateTime? @map("next_run_at")
  metadata        Json?
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime @map("updated_at") @updatedAt

  @@index([agentId, enabled])
  @@index([agentId])
  @@index([enabled])
  @@index([nextRunAt])
  @@index([organizationId])
  @@index([userId])
}

model AiAgentTasks {
  id                   String     @id @default(uuid())
  agentId             String? @map("agent_id")
  runId               String? @map("run_id")
  parentTaskId       String? @map("parent_task_id")
  assignedToAgentId String? @map("assigned_to_agent_id")
  organizationId      String @map("organization_id")
  userId              String @map("user_id")
  title                String
  description          String?
  status               TaskStatus @default(PENDING)
  priority             Int        @default(0)
  input                Json?
  output               Json?
  error                String?
  toolType            String? @map("tool_type")
  toolConfig          Json? @map("tool_config")
  result               Json?
  startedAt           DateTime? @map("started_at")
  completedAt         DateTime? @map("completed_at")
  duration             Int?
  metadata             Json?
  createdAt           DateTime   @default(now()) @map("created_at")
  updatedAt           DateTime @map("updated_at") @updatedAt

  @@index([agentId])
  @@index([agentId, status])
  @@index([assignedToAgentId])
  @@index([organizationId])
  @@index([parentTaskId])
  @@index([runId])
  @@index([runId, status])
  @@index([status])
  @@index([userId])
}

model AiAgentTools {
  id              String        @id @default(uuid())
  agentId        String @map("agent_id")
  organizationId String @map("organization_id")
  userId         String @map("user_id")
  type            AgentToolType
  name            String
  description     String?
  config          Json          @default("{}")
  enabled         Boolean       @default(true)
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime @map("updated_at") @updatedAt

  @@unique([agentId, name])
  @@index([agentId])
  @@index([agentId, type])
  @@index([organizationId])
  @@index([type])
  @@index([userId])
}

model AiAgentVersions {
  id            String   @id @default(uuid())
  agentId      String @map("agent_id")
  version       Int
  systemPrompt String? @map("system_prompt")
  config        Json     @default("{}")
  memoryConfig Json     @default("{}") @map("memory_config")
  toolConfig   Json     @default("{}") @map("tool_config")
  createdAt    DateTime @default(now()) @map("created_at")

  @@unique([agentId, version])
  @@index([agentId])
  @@index([createdAt])
}

model AiAgents {
  id                 String          @id @default(uuid())
  organizationId    String @map("organization_id")
  userId            String @map("user_id")
  name               String
  description        String?
  systemPrompt      String? @map("system_prompt")
  status             AgentStatus     @default(DRAFT)
  visibility         AgentVisibility @default(ORGANIZATION)
  model              String          @default("gpt-4")
  provider           String          @default("openai")
  temperature        Float           @default(0.7)
  maxTokens         Int             @default(4096) @map("max_tokens")
  memoryConfig      Json            @default("{}") @map("memory_config")
  toolConfig        Json            @default("{}") @map("tool_config")
  metadata           Json?
  currentVersionId String? @map("current_version_id")
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime @map("updated_at") @updatedAt
  deletedAt         DateTime? @map("deleted_at")

  @@index([deletedAt])
  @@index([organizationId])
  @@index([organizationId, status])
  @@index([status])
  @@index([userId])
  @@index([userId, status])
}

model AiCache {
  id          String   @id @default(uuid())
  promptHash String @map("prompt_hash")
  voiceHash  String? @map("voice_hash")
  brandHash  String? @map("brand_hash")
  platform    String   @default("")
  tone        String   @default("")
  output      String
  model       String   @default("")
  tokensUsed Int      @default(0) @map("tokens_used")
  createdAt  DateTime @default(now()) @map("created_at")
  expiresAt  DateTime @map("expires_at")

  @@unique([promptHash, platform, tone, voiceHash, brandHash])
  @@index([expiresAt])
}

model AiJobSteps {
  id           String          @id @default(uuid())
  jobId       String @map("job_id")
  step         String
  status       AiJobStepStatus @default(PENDING)
  message      String?
  startedAt   DateTime? @map("started_at")
  completedAt DateTime? @map("completed_at")
  duration     Int?
  metadata     Json?
  createdAt   DateTime        @default(now()) @map("created_at")

  job AiJobs @relation(fields: [jobId], references: [id])

  @@index([jobId])
  @@index([jobId, step])
}

model AiJobs {
  id                 String      @id @default(uuid())
  userId            String @map("user_id")
  status             AiJobStatus @default(QUEUED)
  provider           String      @default("morphllm")
  model              String      @default("")
  inputContent      String @map("input_content")
  outputContent     String? @map("output_content")
  outputFormat      String @map("output_format")
  voiceProfileId   String? @map("voice_profile_id")
  brandKitId       String? @map("brand_kit_id")
  promptTemplate    String? @map("prompt_template")
  promptVersion     Int         @default(1) @map("prompt_version")
  templateVersion   Int         @default(1) @map("template_version")
  providerVersion   String? @map("provider_version")
  generationVersion Int         @default(1) @map("generation_version")
  promptTokens      Int         @default(0) @map("prompt_tokens")
  completionTokens  Int         @default(0) @map("completion_tokens")
  totalTokens       Int         @default(0) @map("total_tokens")
  estimatedCost     Float       @default(0) @map("estimated_cost")
  duration           Int?
  priority           Int         @default(0)
  progress           Float       @default(0)
  error              String?
  retryCount        Int         @default(0) @map("retry_count")
  maxRetries        Int         @default(4) @map("max_retries")
  metadata           Json?
  startedAt         DateTime? @map("started_at")
  completedAt       DateTime? @map("completed_at")
  cancelledAt       DateTime? @map("cancelled_at")
  createdAt         DateTime    @default(now()) @map("created_at")
  updatedAt         DateTime @map("updated_at") @updatedAt

  steps AiJobSteps[]

  @@index([provider, createdAt])
  @@index([status, createdAt])
  @@index([userId, createdAt])
  @@index([userId])
  @@index([userId, status])
}

model AiModels {
  id              String            @id @default(uuid())
  providerId     String @map("provider_id")
  name            String
  displayName    String @map("display_name")
  capabilities    ModelCapability[]
  contextWindow  Int               @default(4096) @map("context_window")
  maxTokens      Int               @default(4096) @map("max_tokens")
  costPerInput  Float             @default(0) @map("cost_per_input")
  costPerOutput Float             @default(0) @map("cost_per_output")
  costPerCached Float             @default(0) @map("cost_per_cached")
  isEnabled      Boolean           @default(true) @map("is_enabled")
  metadata        Json?
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime @map("updated_at") @updatedAt

  @@unique([providerId, name])
  @@index([capabilities])
  @@index([contextWindow])
  @@index([providerId])
  @@index([providerId, isEnabled])
}

model AiProviderCosts {
  id              String    @id @default(uuid())
  providerId     String @map("provider_id")
  model           String
  costPerInput  Float     @default(0) @map("cost_per_input")
  costPerOutput Float     @default(0) @map("cost_per_output")
  costPerCached Float     @default(0) @map("cost_per_cached")
  effectiveFrom  DateTime  @default(now()) @map("effective_from")
  effectiveTo    DateTime? @map("effective_to")
  createdAt      DateTime  @default(now()) @map("created_at")

  @@unique([providerId, model, effectiveFrom])
  @@index([effectiveFrom])
  @@index([model])
  @@index([providerId])
}

model AiProviderEvents {
  id          String   @id @default(uuid())
  providerId String @map("provider_id")
  eventType  String @map("event_type")
  message     String
  metadata    Json?
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@index([eventType])
  @@index([providerId, createdAt])
  @@index([providerId])
}

model AiProviders {
  id            String            @id @default(uuid())
  name          String            @unique
  displayName  String @map("display_name")
  type          ProviderType
  baseUrl      String? @map("base_url")
  apiKey       String? @map("api_key")
  defaultModel String @map("default_model")
  models        String[]
  capabilities  ModelCapability[]
  priority      Int               @default(999)
  isEnabled    Boolean           @default(true) @map("is_enabled")
  config        Json?
  metadata      Json?
  createdAt    DateTime          @default(now()) @map("created_at")
  updatedAt    DateTime @map("updated_at") @updatedAt

  @@index([isEnabled])
  @@index([priority])
  @@index([type])
  @@index([type, isEnabled])
}

model AiRequests {
  id                String        @id @default(uuid())
  organizationId   String @map("organization_id")
  userId           String @map("user_id")
  providerId       String @map("provider_id")
  model             String
  type              String        @default("chat")
  promptTokens     Int           @default(0) @map("prompt_tokens")
  completionTokens Int           @default(0) @map("completion_tokens")
  cachedTokens     Int           @default(0) @map("cached_tokens")
  totalTokens      Int           @default(0) @map("total_tokens")
  estimatedCost    Float         @default(0) @map("estimated_cost")
  latency           Int           @default(0)
  status            RequestStatus @default(PENDING)
  error             String?
  requestedAt      DateTime      @default(now()) @map("requested_at")
  completedAt      DateTime? @map("completed_at")
  createdAt        DateTime      @default(now()) @map("created_at")

  @@index([model])
  @@index([organizationId, createdAt])
  @@index([organizationId])
  @@index([organizationId, status])
  @@index([providerId])
  @@index([providerId, status])
  @@index([requestedAt])
  @@index([status])
  @@index([userId, createdAt])
  @@index([userId])
}

model AiUsage {
  id                String   @id @default(uuid())
  organizationId   String @map("organization_id")
  userId           String @map("user_id")
  providerId       String @map("provider_id")
  model             String
  promptTokens     Int      @default(0) @map("prompt_tokens")
  completionTokens Int      @default(0) @map("completion_tokens")
  cachedTokens     Int      @default(0) @map("cached_tokens")
  totalTokens      Int      @default(0) @map("total_tokens")
  estimatedCost    Float    @default(0) @map("estimated_cost")
  requestCount     Int      @default(0) @map("request_count")
  date              DateTime
  createdAt        DateTime @default(now()) @map("created_at")

  @@unique([organizationId, providerId, model, date])
  @@index([date])
  @@index([model])
  @@index([organizationId, date])
  @@index([organizationId])
  @@index([providerId, date])
  @@index([providerId])
  @@index([userId])
}

model AiUsageDaily {
  id                      String   @id @default(uuid())
  organizationId         String? @map("organization_id")
  providerId             String? @map("provider_id")
  model                   String?
  date                    DateTime
  totalRequests          Int      @default(0) @map("total_requests")
  successfulRequests     Int      @default(0) @map("successful_requests")
  failedRequests         Int      @default(0) @map("failed_requests")
  totalPromptTokens     Int      @default(0) @map("total_prompt_tokens")
  totalCompletionTokens Int      @default(0) @map("total_completion_tokens")
  totalCachedTokens     Int      @default(0) @map("total_cached_tokens")
  totalTokens            Int      @default(0) @map("total_tokens")
  totalCost              Float    @default(0) @map("total_cost")
  averageLatency         Float    @default(0) @map("average_latency")
  createdAt              DateTime @default(now()) @map("created_at")

  @@index([date])
  @@index([model])
  @@index([organizationId, date])
  @@index([organizationId])
  @@index([providerId, date])
  @@index([providerId])
}

model AnalyticsAlertEvents {
  id              String    @id @default(uuid())
  alertId        String @map("alert_id")
  organizationId String @map("organization_id")
  metric          String
  value           Float
  condition       String
  threshold       Float
  message         String
  status          String    @default("triggered")
  acknowledgedAt DateTime? @map("acknowledged_at")
  resolvedAt     DateTime? @map("resolved_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  @@index([alertId])
  @@index([organizationId])
}

model AnalyticsAlerts {
  id                String    @id @default(uuid())
  organizationId   String @map("organization_id")
  userId           String @map("user_id")
  name              String
  description       String?
  metric            String
  condition         String
  threshold         Float
  window            Int       @default(300)
  enabled           Boolean   @default(true)
  channels          Json      @default("[]")
  lastTriggeredAt DateTime? @map("last_triggered_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime @map("updated_at") @updatedAt

  @@index([organizationId])
}

model AnalyticsBenchmarks {
  id              String   @id @default(uuid())
  organizationId String @map("organization_id")
  userId         String @map("user_id")
  name            String
  description     String?
  metric          String
  period          String   @default("monthly")
  groupBy         String?
  filters         Json?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @map("updated_at") @updatedAt

  @@index([organizationId])
}

model AnalyticsDashboards {
  id              String   @id @default(uuid())
  organizationId String @map("organization_id")
  userId         String @map("user_id")
  title           String
  description     String?
  config          Json     @default("{}")
  layout          Json?
  isDefault       Boolean  @default(false)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @map("updated_at") @updatedAt

  @@index([organizationId])
}

model AnalyticsKpis {
  id              String   @id @default(uuid())
  organizationId String @map("organization_id")
  userId         String @map("user_id")
  name            String
  description     String?
  metric          String
  formula         String?
  unit            String?
  target          Float?
  warning         Float?
  critical        Float?
  direction       String   @default("up")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @map("updated_at") @updatedAt

  @@index([organizationId])
}

model AnalyticsReports {
  id                String    @id @default(uuid())
  organizationId   String @map("organization_id")
  userId           String @map("user_id")
  title             String
  description       String?
  type              String    @default("custom")
  config            Json      @default("{}")
  filters           Json?
  schedule          Json?
  format            String?   @default("pdf")
  lastGeneratedAt DateTime? @map("last_generated_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime @map("updated_at") @updatedAt

  @@index([organizationId])
}

model AnalyticsSegments {
  id              String   @id @default(uuid())
  organizationId String @map("organization_id")
  userId         String @map("user_id")
  name            String
  description     String?
  type            String   @default("customer")
  criteria        Json     @default("{}")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @map("updated_at") @updatedAt

  @@index([organizationId])
}

model ApiKeys {
  id              String    @id @default(uuid())
  organizationId String @map("organization_id")
  userId         String @map("user_id")
  name            String
  keyPrefix      String @map("key_prefix")
  keyHash        String @map("key_hash")
  permissions     String[]
  scopes          String[]
  allowedIps     String[] @map("allowed_ips")
  lastUsedAt    DateTime? @map("last_used_at")
  expiresAt      DateTime? @map("expires_at")
  isActive       Boolean   @default(true) @map("is_active")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime @map("updated_at") @updatedAt
  environment     String    @default("live")
  dailyQuota     Int? @map("daily_quota")
  monthlyQuota   Int? @map("monthly_quota")
  dailyUsed      Int       @default(0) @map("daily_used")
  monthlyUsed    Int       @default(0) @map("monthly_used")
  quotaResetAt  DateTime? @map("quota_reset_at")

  @@index([expiresAt])
  @@index([keyHash])
  @@index([organizationId])
  @@index([organizationId, isActive])
  @@index([userId])
}

model ApiRequestLogs {
  id              String   @id @default(uuid())
  organizationId String? @map("organization_id")
  apiKeyId      String? @map("api_key_id")
  userId         String? @map("user_id")
  method          String
  path            String
  status          Int
  latencyMs       Int @map("duration")
  ipAddress      String? @map("ip_address")
  userAgent      String? @map("user_agent")
  requestId      String? @map("request_id")
  idempotencyKey String? @map("idempotency_key")
  rateLimited    Boolean  @default(false) @map("rate_limited")
  error           String?
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([apiKeyId])
  @@index([createdAt])
  @@index([organizationId, createdAt])
  @@index([organizationId])
  @@index([path, createdAt])
  @@index([status, createdAt])
}

model AuditLogs {
  id         String     @id @default(uuid())
  event      AuditEvent
  userId    String? @map("user_id")
  email      String?
  ip         String?
  userAgent String? @map("user_agent")
  action     String
  metadata   Json?
  createdAt DateTime   @default(now()) @map("created_at")

  @@index([createdAt])
  @@index([event])
  @@index([userId, createdAt])
  @@index([userId])
}

model BrandKits {
  id                  String   @id @default(uuid())
  companyName        String @map("company_name")
  brandColors        String[] @map("brand_colors")
  brandVoice         String @map("brand_voice")
  logoUrl            String @map("logo_url")
  userId             String @map("user_id")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @map("updated_at") @updatedAt
  companyDescription String? @map("company_description")
