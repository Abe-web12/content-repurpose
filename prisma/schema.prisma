  payoutsEnabled    Boolean  @default(false) @map("payouts_enabled")
  detailsSubmitted  Boolean  @default(false) @map("details_submitted")
  totalEarnedCents  Int      @default(0) @map("total_earned_cents")
  totalPayoutCents  Int      @default(0) @map("total_payout_cents")
  status            String   @default("PENDING")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @map("updated_at") @updatedAt

  @@index([stripeAccountId])
  @@index([status])
}

model MarketplacePurchases {
  id                   String   @id @default(uuid())
  listingId           String @map("listing_id")
  organizationId      String @map("organization_id")
  stripeSessionId     String @unique @map("stripe_session_id")
  stripePaymentIntentId String? @map("stripe_payment_intent_id")
  amountCents          Int      @map("amount_cents")
  feeCents             Int      @map("fee_cents")
  status               String   @default("PENDING")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @map("updated_at") @updatedAt

  @@index([listingId])
  @@index([organizationId])
  @@index([status])
}

model PushSubscriptions {
  id              String   @id @default(uuid())
  userId         String @map("user_id")
  organizationId String @map("organization_id")
  endpoint        String   @unique
  p256dhKey       String @map("p256dh_key")
  authKey         String @map("auth_key")
  deviceType      String? @map("device_type")
  userAgent       String?
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @map("updated_at") @updatedAt

  @@index([userId])
  @@index([organizationId])
  @@index([isActive])
}

model AiPrompts {
  id              String   @id @default(uuid())
  organizationId String @map("organization_id")
  userId         String @map("user_id")
  name            String
  promptText     String @map("prompt_text")
  version         Int      @default(1)
  parentId       String? @map("parent_id")
  metadata        Json?
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @map("updated_at") @updatedAt

  @@unique([organizationId, name, version])
  @@index([organizationId])
  @@index([userId])
  @@index([parentId])
}

model AiPromptVersions {
  id              String   @id @default(uuid())
  promptId       String @map("prompt_id")
  version         Int
  promptText     String @map("prompt_text")
  changeLog       String?
  createdBy       String @map("created_by")
  createdAt       DateTime @default(now()) @map("created_at")

  @@unique([promptId, version])
  @@index([promptId])
}

model AiMemoryEntries {
  id              String   @id @default(uuid())
  organizationId String @map("organization_id")
  userId         String @map("user_id")
  sessionId      String? @map("session_id")
  role            String   @default("user")
  content         String
  metadata        Json?
  tokenCount     Int? @map("token_count")
  createdAt       DateTime @default(now()) @map("created_at")
  expiresAt       DateTime? @map("expires_at")

  @@index([organizationId, userId])
  @@index([organizationId, sessionId])
  @@index([userId])
  @@index([sessionId])
  @@index([expiresAt])
}

model AiPromptTemplates {
  id              String   @id @default(uuid())
  organizationId String @map("organization_id")
  name            String
  description     String?
  category        String   @default("custom")
  systemPrompt   String @map("system_prompt")
  userTemplate   String @map("user_template")
  variables       String[]
  tags            String[]
  isBuiltIn       Boolean  @default(false) @map("is_built_in")
  usageCount      Int      @default(0) @map("usage_count")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @map("updated_at") @updatedAt

  @@unique([organizationId, name])
  @@index([organizationId, category])
  @@index([organizationId, isBuiltIn])
}
