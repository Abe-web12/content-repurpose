# ===========================================
# NEON.TECH (SERVERLESS POSTGRESQL)
# Get from: https://console.neon.tech → Project → Connection Details
# Use the pooled connection string for serverless (Prisma from serverless)
# ===========================================
# Pooled connection (for Prisma Client in serverless / Vercel)
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.us-east-2.aws.neon.tech/repurposeai?sslmode=require"

# Direct connection (for Prisma Migrate / introspection — no pooler)
DIRECT_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/repurposeai?sslmode=require"

# ===========================================
# CLERK (Authentication)
# Get from: https://dashboard.clerk.com → Applications → Your App → API Keys
# ===========================================
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/signup
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ===========================================
# MORPHLLM AI (OpenAI-compatible)
# Get your API key from: https://morphllm.com
# Model: morph-glm52-744b
# ===========================================
AI_API_KEY=sk-your-morphllm-api-key
AI_BASE_URL=https://api.morphllm.com/v1
AI_MODEL=morph-glm52-744b

# ===========================================
# STRIPE
# Get from: https://dashboard.stripe.com/test/apikeys
# Products: Create "Starter" ($19/mo) and "Pro" ($49/mo) → copy Price IDs
# Webhook: Run `stripe listen --forward-to localhost:3000/api/billing/webhook`
# ===========================================
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-signing-secret
STRIPE_STARTER_PRICE_ID=price_your-starter-price-id
STRIPE_PRO_PRICE_ID=price_your-pro-price-id

# ===========================================
# SENTRY
# Get from: https://sentry.io → Settings → Projects → Client Keys (DSN)
# ===========================================
SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
NEXT_PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
SENTRY_ORG=your-sentry-org
SENTRY_PROJECT=your-sentry-project

# ===========================================
# UPSTASH / REDIS
# Get from: https://console.upstash.com → Redis Database → REST API
# ===========================================
REDIS_URL=https://your-redis-url.upstash.io
REDIS_TOKEN=your-redis-token

# ===========================================
# CRON SECRET
# Shared secret between Vercel Cron and the /api/cron/process-posts endpoint
# ===========================================
CRON_SECRET=your-cron-secret-change-me

# ===========================================
# ENCRYPTION KEY
# Used to encrypt sensitive credentials in the database (OAuth tokens, API keys, webhook secrets).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ===========================================
ENCRYPTION_KEY=your-256-bit-hex-encryption-key

# ===========================================
# RESEND
# Get from: https://resend.com → API Keys
# Must verify sending domain in Resend (add SPF, DKIM, DMARC DNS records)
# ===========================================
RESEND_API_KEY=re_your-resend-api-key
RESEND_FROM_EMAIL=noreply@your-domain.com

# ===========================================
# CLERK WEBHOOK SECRET
# Get from: https://dashboard.clerk.com → Webhooks → Create Endpoint
# Endpoint URL: https://your-domain.com/api/webhooks/clerk
# Subscribe to: user.created, user.updated, user.deleted
# ===========================================
CLERK_WEBHOOK_SECRET=whsec_your-clerk-webhook-secret

# ===========================================
# CLOUDINARY
# Get from: https://cloudinary.com → Dashboard
# ===========================================
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ===========================================
# SOCIAL / OAUTH
# LinkedIn: https://www.linkedin.com/developers → Apps → Your App → Auth
#   Add redirect URL: https://your-domain.com/api/social/linkedin
# X/Twitter: https://developer.twitter.com → Portal → Projects & Apps → App Settings
#   Add redirect URL: https://your-domain.com/api/social/twitter
# ===========================================
LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret
TWITTER_CLIENT_ID=your-twitter-client-id
TWITTER_CLIENT_SECRET=your-twitter-client-secret

# ===========================================
# APP
# Change NEXT_PUBLIC_APP_URL to your domain after deploying to Vercel
# ===========================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=RepurposeAI
